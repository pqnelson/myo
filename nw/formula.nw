\begin{node}
The grammar for formulas is, well, what we would expect. We should
probably keep formulas as an abstract data type, following our design
decision for terms. The advantage is that constructors for quantifiers
can check it is given a variable.
\end{node}

<<Formula.sig>>=
signature Formula = sig
  type t;

  val mk_falsum : unit -> t;
  val mk_pred : string * (Term.t list) -> t;
  val mk_eq : Term.t * Term.t -> t;
  val mk_in : Term.t * Term.t -> t;
  val mk_not : t -> t;
  val mk_and : t * t -> t;
  val mk_or  : t * t -> t;
  val mk_imp : t * t -> t;
  val mk_iff : t * t -> t;
  val mk_forall : Term.t * t -> t;
  val mk_exists : Term.t * t -> t;

  val is_falsum : t -> bool;
  val is_pred : t -> bool;
  val is_eq : t -> bool;
  val is_in : t -> bool;
  val is_not : t -> bool;
  val is_and : t -> bool;
  val is_or : t -> bool;
  val is_imp : t -> bool;
  val is_iff : t -> bool;
  val is_forall : t -> bool;
  val is_exists : t -> bool;

  val dest_pred : t -> string * (Term.t list);
  val dest_eq : t -> Term.t * Term.t;
  val dest_in : t -> Term.t * Term.t;
  val dest_not : t -> t;
  val dest_and : t -> t * t;
  val dest_or  : t -> t * t;
  val dest_imp : t -> t * t;
  val dest_iff : t -> t * t;
  val dest_forall : t -> Term.t * t;
  val dest_exists : t -> Term.t * t;

  val subst : Term.t -> Term.t -> t -> t;
  val fv : t -> Term.t list;
  val bv : t -> Term.t list;

  val precedence : t -> t -> order;
  val compare : t * t -> order;
end;
@


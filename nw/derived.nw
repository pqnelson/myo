    val expected = Formula.mk_imp(Formula.mk_or(Formula.mk_forall(x,A),C),
                                  Formula.mk_forall(x, Formula.mk_or(A,C)));
    val actual = Thm.concl (Derived.all_disjL x A C);
  in
    Formula.eq expected actual
  end;

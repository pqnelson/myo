\item $\vdash(C\implies\forall x\ldotp A[x])\implies(\forall x\ldotp(C\implies A[x]))$
  by discharging%13
\item $\vdash(\forall x\ldotp(C\implies A[x]))\iff(C\implies\forall x\ldotp A[x])$
  by $\Leftrightarrow$-intro(6, 13)\qedhere%14
\end{enumerate}
\end{proof}


\def\ysg@tag@format#1{\textup{\footnotesize\texttt{[#1]}}}
\@ifundefined{default@tag}{%
  \@ifundefined{tag}%
               {\gdef\og@tag#1{}}% silently gobble tags
               {\global\let\og@tag\tag}%
}{\global\let\og@tag\dft@tag}

\def\default@tag{\let\tag\og@tag}
\newskip\ysg@tagskip
\ysg@tagskip\z@
\let\og@xsect\@xsect

\def\@xsect#1{\ysg@tagskip#1\relax% update \ysg@tagskip
  \ifdim\ysg@tagskip>\z@%            if there is any vertical skip
  \advance\ysg@tagskip\baselineskip% then add a baselineskip to ysg@tagskip
  \fi%
  \og@xsect{#1}} % do the original \@xsect{...} command

\@ifclassloaded{amsbook}{
  \newcommand\ysg@enable@chapter@tags{%
    \ysg@tagskip\skip@\relax% update \ysg@tagskip
    \ifdim\ysg@tagskip>\z@%
    \advance\ysg@tagskip\normalbaselineskip%
    \fi%
    \providetags%
  }
  \AddToHook{cmd/@makechapterhead/after}{\ysg@enable@chapter@tags}
}{}
\newcommand\providetags{%
  \gdef\tag##1{%
    \label{##1}%
    \ifHTML%
      \ysg@error{\tag is unimplemented for HTML output}%
    \else%
      \marginnote{\ysg@tag@format{##1}}[\ifdim\ysg@tagskip>\z@-\ysg@tagskip\else\z@\fi]%
    \fi%
    \default@tag    % reset the tag value to be its default
    \ysg@tagskip\z@ % reset the ysg@tagskip value
    \ignorespaces%
  }%
}
\AddToHook{cmd/@sect/after}{\providetags}
\newcommand\ysg@equation@tag{
  \let\og@tag\tag
  \providetags
}
\newcommand\tagequations{
  \AddToHook{cmd/equation/after}{\ysg@equation@tag}
}
\iftagequations% if the user wants us to have equations provide tags
  \tagequations% then we do it here and now
\fi

\newcommand\tagtheorems{
  \let\og@xnthm\@xnthm
  \gdef\@xnthm##1##2{%
    \AddToHook{env/##2/begin}{\providetags}%
    \og@xnthm{##1}{##2}%
  }
}
\iftagtheorems% if the user wants us to have theorems provide tags
  \tagtheorems% then we do it here and now
\fi

